{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "isolate-runtime/src/inject/**/*.ts",
    "isolate-runtime/src/common/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
