{
	"name": "nanosandbox",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@8.15.6",
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch",
		"dev": "turbo run dev",
		"shell": "pnpm build -F nanosandbox && pnpm --filter @nanosandbox/terminal start",
		"lint": "biome check",
		"lint:fix": "biome check --write"
	},
	"pnpm": {
		"overrides": {
			"@wasmer/sdk": "file:../misc/wasmer-js"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.9",
		"@types/node": "^22.10.2",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"turbo": "^2.3.3",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
